{
  "appId": "com.jivon.portfolio",
  "appName": "Jivon资产面板",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "SplashScreen": {
      "launchShowDuration": 2000,
      "launchAutoHide": true,
      "backgroundColor": "#0b0f19",
      "androidScaleType": "CENTER_CROP"
    },
    "CapacitorUpdater": {
      "autoUpdate": false,
      "appReadyTimeout": 10000,
      "responseTimeout": 20,
      "autoDeleteFailed": true,
      "autoDeletePrevious": true,
      "resetWhenUpdate": true
    }
  },
  "android": {
    "buildOptions": {
      "keystorePath": "",
      "keystoreAlias": "",
      "keystorePassword": "",
      "keystoreAliasPassword": ""
    }
  }
}
