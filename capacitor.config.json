{
  "appId": "com.jivon.portfolio",
  "appName": "Jivon资产面板",
  "webDir": "www",
  "bundledWebRuntime": false,
  "server": {
    "androidScheme": "https",
    "cleartext": true
  },
  "plugins": {
    "CapacitorUpdater": {
      "autoUpdate": true,
      "updateUrl": "https://capgo.app/api/v2/updates",
      "appReadyTimeout": 10000,
      "autoDeleteFailed": true,
      "autoDeletePrevious": true,
      "resetWhenUpdate": true,
      "periodCheckDelay": 3600
    }
  },
  "android": {
    "adjustMarginsForEdgeToEdge": "force"
  }
}
