{
	"appId": "com.jivon.portfolio",
	"appName": "Jivon资产面板",
	"webDir": "www",
	"bundledWebRuntime": false,
	"server": {
		"androidScheme": "https",
		"cleartext": true
	},
	"plugins": {
		"CapacitorUpdater": {
			"autoUpdate": true,
			"updateUrl": "https://jivon-update.your-subdomain.workers.dev/api/update",
			"appReadyTimeout": 10000,
			"autoDeleteFailed": true,
			"autoDeletePrevious": true,
			"resetWhenUpdate": true,
			"periodCheckDelay": 3600
		}
	},
	"android": {
		"adjustMarginsForEdgeToEdge": "force"
	}
}
